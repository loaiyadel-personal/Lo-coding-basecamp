# Copy this file to .env and fill in your values

# MongoDB
MONGO_URI=mongodb://localhost:27017/cv_website

# Server
PORT=5000
NODE_ENV=development

# JWT (use a long random string — e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# Admin credentials (used only during initial seed / first login setup)
ADMIN_PASSWORD=change_me_before_use
