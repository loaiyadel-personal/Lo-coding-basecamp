# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/cv_website?retryWrites=true&w=majority&appName=AppName

# Server
PORT=3001
NODE_ENV=development

# JWT (generate a strong secret — run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=7d

# Admin panel password
ADMIN_PASSWORD=change_me_before_use
